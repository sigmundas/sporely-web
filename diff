+  setInaturalistApiTokenRecord({
+    apiToken,
+    createdAt: apiCreatedAtSeconds * 1000,
+    expiresAt: apiExpiresAt,
+    accessToken,
+    accessTokenCreatedAt: accessCreatedAtSeconds * 1000,
+    accessTokenExpiresAt: Number(payload?.access_expires_at || payload?.accessExpiresAt || ((accessCreatedAtSeconds * 1000) + (accessExpiresInSeconds * 1000))) || (Date.now() + DEFAULT_ACCESS_TOKEN_TTL_MS),
+    refreshToken,
+  })
+
+  return {
+    username: String(username || '').trim(),
+    apiToken,
+    accessToken,
+    refreshToken,
+    createdAt: apiCreatedAtSeconds * 1000,
+    expiresAt: apiExpiresAt,
+  }
+}
+
+async function _fetchInaturalistCurrentUser(apiToken) {
+  const response = await fetch('https://api.inaturalist.org/v1/users/me', {
+    headers: {
+      Accept: 'application/json',
+      Authorization: `Bearer ${String(apiToken || '').trim()}`,
+    },
+  })
+  const payload = await response.json().catch(() => ({}))
+  if (!response.ok) {
+    throw new Error(payload?.error_description || payload?.error || payload?.message || 'iNaturalist user lookup failed')
+  }
+  return payload
+}
+
+function _extractInaturalistUsername(payload) {
+  const candidates = [payload?.results, payload?.user, payload?.data, payload]
+
+  for (const candidate of candidates) {
+    if (Array.isArray(candidate)) {
+      for (const item of candidate) {
+        const username = _extractInaturalistUsername(item)
+        if (username) return username
+      }
+      continue
+    }
+
+    if (!candidate || typeof candidate !== 'object') continue
+
+    for (const key of ['login', 'username', 'user_login', 'preferred_username']) {
+      const value = String(candidate[key] || '').trim()
+      if (value) return value
+    }
+  }
+
+  return ''
+}
+
+async function _completeInaturalistLoginFromUrl(urlInput, { clearBrowserUrl = false } = {}) {
+  if (!urlInput) return null
+  const url = urlInput instanceof URL ? new URL(urlInput.toString()) : new URL(String(urlInput))
+  const code = String(url.searchParams.get('code') || '').trim()
+  const state = String(url.searchParams.get('state') || '').trim()
+  const error = String(url.searchParams.get('error') || '').trim()
+  const errorDescription = String(url.searchParams.get('error_description') || '').trim()
+  if (!code && !error) return null
+
+  const clearCallbackParams = () => {
+    if (!clearBrowserUrl || typeof window === 'undefined' || !window.history?.replaceState || !window.location) return
+    const current = new URL(window.location.href)
+    current.searchParams.delete('code')
+    current.searchParams.delete('state')
+    current.searchParams.delete('scope')
+    current.searchParams.delete('code_verifier')
+    current.searchParams.delete('redirect_uri')
+    current.searchParams.delete('error')
+    current.searchParams.delete('error_description')
+    try {
+      window.history.replaceState({}, document.title, current.toString())
+    } catch (_) {}
+  }
+
+  const pending = _getPendingOAuthRecord()
+  if (!pending?.state || !pending?.redirectUri) {
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    throw new Error(errorDescription || error || 'Missing iNaturalist authorization state.')
+  }
+  if (error) {
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    throw new Error(errorDescription || error || 'iNaturalist authorization failed.')
+  }
+  if (state !== pending.state) {
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    throw new Error('iNaturalist authorization state mismatch.')
+  }
+  if (!pending.codeVerifier) {
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    throw new Error('Missing PKCE verifier. Please try logging in again.')
+  }
+
+  try {
+    const payload = await _exchangeOAuthCode(code, pending.codeVerifier, pending.redirectUri)
+    const saved = _persistOAuthTokens(payload, getInaturalistLoginDraft().username)
+    try {
+      const mePayload = await _fetchInaturalistCurrentUser(saved.apiToken || saved.accessToken)
+      const username = _extractInaturalistUsername(mePayload)
+      if (username) {
+        setInaturalistLoginDraft(username)
+        saved.username = username
+      }
+    } catch (lookupError) {
+      console.warn('iNaturalist user lookup failed after login:', lookupError)
+    }
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    return saved
+  } catch (err) {
+    _clearPendingOAuthRecord()
+    clearCallbackParams()
+    throw err
+  }
+}
+
+export async function completeInaturalistLoginFromCallback() {
+  if (typeof window === 'undefined' || !window.location) return null
+  return _completeInaturalistLoginFromUrl(window.location.href, { clearBrowserUrl: true })
+}
+
+export async function completeInaturalistLoginFromCallbackUrl(callbackUrl) {
