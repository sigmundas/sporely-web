+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify(body),
+  })
+  const payload = await response.json().catch(() => ({}))
+  if (!response.ok) {
+    throw new Error(payload?.message || payload?.error || 'iNaturalist login failed')
+  }
+  return payload
+}
+
+async function _exchangeRefreshToken(refreshToken, redirectUri = _buildRedirectUri()) {
+  const response = await _authorizedWorkerFetch('/inaturalist/login', {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({
+      grant_type: 'refresh_token',
+      refresh_token: refreshToken,
+      redirect_uri: redirectUri,
+      client_id: DEFAULT_CLIENT_ID,
+    }),
+  })
+  const payload = await response.json().catch(() => ({}))
+  if (!response.ok) {
+    throw new Error(payload?.message || payload?.error || 'iNaturalist token refresh failed')
+  }
