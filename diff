+  const accessCreatedAtSeconds = Number(payload?.access_created_at || payload?.accessCreatedAt || payload?.created_at || payload?.createdAt || Math.floor(Date.now() / 1000)) || Math.floor(Date.now() / 1000)
+  const accessExpiresInSeconds = Number(payload?.access_expires_in || payload?.accessExpiresIn || payload?.expires_in || payload?.expiresIn || (DEFAULT_ACCESS_TOKEN_TTL_MS / 1000)) || (DEFAULT_ACCESS_TOKEN_TTL_MS / 1000)
+  const apiCreatedAtSeconds = Number(payload?.api_token_created_at || payload?.apiTokenCreatedAt || accessCreatedAtSeconds) || accessCreatedAtSeconds
+  const apiExpiresInSeconds = Number(payload?.api_token_expires_in || payload?.apiTokenExpiresIn || (DEFAULT_TOKEN_TTL_MS / 1000)) || (DEFAULT_TOKEN_TTL_MS / 1000)
+  const apiExpiresAt = Number(payload?.api_token_expires_at || payload?.apiTokenExpiresAt || ((apiCreatedAtSeconds * 1000) + (apiExpiresInSeconds * 1000))) || (Date.now() + DEFAULT_TOKEN_TTL_MS)
